{
  "name": "digital-marketplace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "npx @cloudflare/next-on-pages && wrangler pages deploy .vercel/output/static",
    "pages:build": "npx @cloudflare/next-on-pages",
    "db:migrate": "wrangler d1 migrations apply marketplace-db --remote",
    "db:seed": "wrangler d1 execute marketplace-db --remote --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "next": "15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^17.7.0",
    "nodemailer": "^6.9.14",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/nodemailer": "^6.4.15",
    "typescript": "^5.5.2",
    "tailwindcss": "^3.4.6",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.2.3",
    "wrangler": "^3.63.1"
  }
}